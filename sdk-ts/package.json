{
  "name": "forum-arc-sdk",
  "version": "0.0.1",
  "description": "Arc-native SDK for Covenant Accounts and prediction-market agent operators",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./deployments": {
      "types": "./dist/deployments.d.ts",
      "import": "./dist/deployments.js"
    },
    "./abi": {
      "types": "./dist/abi.d.ts",
      "import": "./dist/abi.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "arc",
    "polymarket",
    "prediction-markets",
    "market-maker",
    "usdc",
    "viem"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ridwannurudeen/forum.git",
    "directory": "sdk-ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "viem": "^2.50.4"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "license": "MIT"
}

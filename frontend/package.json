{
  "name": "forum-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "scripts": {
    "build": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -c tailwind.config.js -i ./src/styles.css -o ./assets/forum.css --minify",
    "dev": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -c tailwind.config.js -i ./src/styles.css -o ./assets/forum.css --watch"
  },
  "devDependencies": {
    "browserslist": "^4.28.2",
    "caniuse-lite": "^1.0.30001793",
    "cross-env": "^10.1.0",
    "tailwindcss": "^3.4.17"
  }
}

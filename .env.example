# Rename to .env locally:  cp env.example .env

# Arc testnet RPC + chain
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_TESTNET_CHAIN_ID=5042002

# Deployer (USE A DEV WALLET — never commit a real key)
DEPLOYER_PRIVATE_KEY=

# Arc-side ERC-20 addresses (VERIFY against docs.arc.io / arcscan before deploy)
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
ARC_EURC_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a

# Polygon (Polymarket V2 lives here)
POLYGON_RPC_URL=
POLYMARKET_BUILDER_CODE=

# Forum deployments (filled after deploy)
FORUM_REGISTRY_ADDRESS=
FORUM_CONFIG_ADDRESS=
FORUM_TRACKRECORD_ADDRESS=
FORUM_FEEDISTRIBUTOR_ADDRESS=
